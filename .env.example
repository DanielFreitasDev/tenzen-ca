# Tenzen CA — configuracao do Docker Compose.
# Copie para .env e ajuste:  cp .env.example .env
# O .env NAO deve ser versionado (contem segredos).

# ---------------------------------------------------------------------------
# Exposicao no host
# ---------------------------------------------------------------------------
# Interface do HOST onde a porta sera publicada. 127.0.0.1 = so a maquina
# local (default seguro). Use 0.0.0.0 para expor na rede — e, nesse caso,
# ligue o basic-auth abaixo.
TENZEN_BIND=127.0.0.1
TENZEN_PORT=8080

# ---------------------------------------------------------------------------
# Aplicacao
# ---------------------------------------------------------------------------
# URL base embutida nos certificados emitidos (CRL DP, AIA, CPS). Precisa ser
# alcancavel por quem for validar os certificados; mantenha coerente com
# TENZEN_BIND/TENZEN_PORT (ex.: http://10.0.0.5:8080 se exposto na rede).
APP_BASE_URL=http://localhost:8080

# Senha dos keystores da AC (root.p12 / issuing.p12). Obrigatoria; gere uma:
#   openssl rand -base64 24
# Trocar a senha depois da primeira subida invalida os keystores existentes.
APP_CA_KEYSTORE_PASSWORD=

# Modo do OID de politica: icp-format (OID formato ICP-Brasil com leaf
# ficticio) ou private-2.25 (OID privado derivado de UUID).
APP_CA_POLICY_MODE=icp-format

# Basic-auth da interface web (CRL/AIA/estaticos continuam publicos).
# Obrigatorio definir uma senha se enabled=true.
APP_SECURITY_BASIC_AUTH_ENABLED=false
APP_SECURITY_BASIC_AUTH_USERNAME=tenzen
APP_SECURITY_BASIC_AUTH_PASSWORD=

# Fuso horario do conteiner (logs; validade dos certificados e sempre UTC).
TZ=America/Fortaleza

# ---------------------------------------------------------------------------
# Build (so mexa se sua rede exigir)
# ---------------------------------------------------------------------------
# Rede dos passos RUN durante o build da imagem. Deixe "default" (rede
# isolada, o normal). Use "host" apenas se a sua internet sai por um proxy
# escutando em localhost (ex.: squid em 127.0.0.1:3128) — nesse caso o
# Dockerfile detecta o proxy do ambiente e configura Maven/Node/npm sozinho.
BUILD_NETWORK=default
